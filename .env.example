# ─────────────────────────────────────────────────────────────
# NEW SZN — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------
# Pooler (runtime) + direct/session connection (migrations). Both required.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-northeast-REGION.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-1-ap-northeast-REGION.pooler.supabase.com:5432/postgres

# --- AI provider ------------------------------------------------
# Powers AI Insights, Loss Debrief, Anomaly summaries, Next Best Action,
# Daily Targets, and Campaign Narratives. OpenAI is the confirmed provider.
OPENAI_API_KEY=""
# Optional alternative provider (leave blank if using OpenAI):
# ANTHROPIC_API_KEY=""

# --- Meta (Facebook / Instagram) Ads ----------------------------
# Used by the hourly + manual ad sync.
META_APP_ID=""
META_APP_SECRET=""
META_SYSTEM_USER_TOKEN=""

# --- Slack ------------------------------------------------------
# Reports, leaderboards, loss debriefs, anomaly alerts, milestones.
SLACK_BOT_TOKEN=""

# --- Email ------------------------------------------------------
# Account invites and password reset links only. Sent via SMTP.
# Defaults target a local Mailpit instance (https://mailpit.axllent.org) —
# run it standalone (binary or `docker run -p 1025:1025 -p 8025:8025 axllent/mailpit`)
# and view caught mail at http://localhost:8025. Point these at a real SMTP
# server (host/port/user/pass) for production delivery.
SMTP_HOST="127.0.0.1"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# --- FX / currency ----------------------------------------------
# Live exchange rates for multi-currency clients.
FX_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Runtime config (needed for the apps to boot)
# ─────────────────────────────────────────────────────────────
NODE_ENV="development"

# Express API
API_PORT="4000"

# Secret for signing sessions / JWTs (role-based auth). Generate a long random value.
AUTH_SECRET=""                    # generate: openssl rand -hex 32
INTERNAL_API_SECRET=""           # generate: openssl rand -hex 32
APP_URL="http://localhost:3000"  # Next.js origin — used for email links
EMAIL_FROM="NEW SZN <invites@new-szn.local>"

# Web → API base URL (exposed to the browser)
NEXT_PUBLIC_API_URL="http://localhost:4000"
